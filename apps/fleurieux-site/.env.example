# .env.example
# Copier en .env et remplir les valeurs

# ── Base de données ──────────────────────────
# SEC-016 : définir DATABASE_URL directement pour éviter la reconstruction inline dans docker-compose
DATABASE_URL="postgresql://fleurieux:MOT_DE_PASSE@localhost:5432/fleurieux"
POSTGRES_USER="fleurieux"
POSTGRES_PASSWORD="MOT_DE_PASSE_A_CHANGER"

# ── Auth (Better Auth) ───────────────────────
# Générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET="GENERER_UN_SECRET_FORT"
# H2 : URL publique de l'app — Better Auth s'en sert pour les contrôles d'origine
# (CSRF) et les callbacks. En dev : http://localhost:3000. En prod : le domaine HTTPS.
BETTER_AUTH_URL="https://fleurieux.info"

# ── Seed ─────────────────────────────────────
# Mot de passe du compte admin créé par prisma/seed.ts
ADMIN_PASSWORD="MOT_DE_PASSE_ADMIN_A_CHANGER"
# Email du compte admin (défaut : admin@fleurieux.info)
# SEC-010 : changer pour ne pas exposer l'email cible dans le code source
ADMIN_EMAIL="admin@fleurieux.info"

# ── URLs ─────────────────────────────────────
# NEXTAUTH_URL est un vestige NextAuth — Better Auth utilise BETTER_AUTH_URL (ci-dessus).
# Conservé seulement si du code legacy le lit encore.
NEXTAUTH_URL="https://fleurieux.info"
NEXT_PUBLIC_URL="https://fleurieux.info"

# ── Web Push (VAPID) ─────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="GENERER_AVEC_web-push_generate-vapid-keys"
VAPID_PRIVATE_KEY="GENERER_AVEC_web-push_generate-vapid-keys"
VAPID_SUBJECT="mailto:admin@fleurieux.info"

# ── SEO ───────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://fleurieux.info"

# ── Upload (optionnel — Minio ou stockage local) ──
# MINIO_ENDPOINT="http://localhost:9000"
# MINIO_ACCESS_KEY="..."
# MINIO_SECRET_KEY="..."
# MINIO_BUCKET="fleurieux-uploads"

# Secret pour les routes cron (à appeler depuis un cron quotidien)
CRON_SECRET=change-me

# ── Bus temps réel (data.grandlyon / SIRI-Lite SYTRAL) ──
# Compte data.grandlyon. Le mot de passe est celui de la « plateforme data »
# (distinct du mot de passe Grand Lyon Connect), à définir via
# https://data.grandlyon.com/portail/fr/mot-de-passe-oublie
# Sans ces variables, la section bus s'affiche « indisponible » (les trains fonctionnent).
GRANDLYON_USER="prenom.nom@exemple.com"
GRANDLYON_PASS="MOT_DE_PASSE_PLATEFORME_DATA"
