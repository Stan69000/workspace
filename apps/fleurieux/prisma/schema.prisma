// prisma/schema.prisma
// Fleurieux-sur-l'Arbresle — Portail de village
// Stack : Next.js 15 · Prisma · PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH (Better Auth)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  prenom        String?
  image         String?
  role          Role      @default(HABITANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  accounts      Account[]
  acteurs       Acteur[]        @relation("ContributeurActeur")
  evenements    Evenement[]     @relation("ContributeurEvenement")
  avis          Avis[]
  actus         Actu[]
  randos        Rando[]         @relation("ContributeurRando")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

enum Role {
  ADMIN        // Accès total
  MODERATEUR   // Modération avis + validation acteurs
  CONTRIBUTEUR // Peut créer/modifier ses propres fiches
  HABITANT     // Peut laisser des avis
}

// ─────────────────────────────────────────────
// ACTEURS LOCAUX
// ─────────────────────────────────────────────

model Acteur {
  id            String        @id @default(cuid())
  slug          String        @unique
  nom           String
  description   String?       // Courte (carte)
  descriptionLongue String?   // Complète (fiche)
  emoji         String?       @default("🏪")
  categorieId   String
  statut        Statut        @default(BROUILLON)
  miseEnAvant   Boolean       @default(false)
  avisActives   Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Coordonnées
  adresse       String?
  codePostal    String?        @default("69210")
  ville         String?        @default("Fleurieux-sur-l'Arbresle")
  telephone     String?
  email         String?
  siteWeb       String?
  latitude      Float?
  longitude     Float?

  // Paiement
  accepteEspeces   Boolean @default(true)
  accepteCB        Boolean @default(false)
  accepteCheque    Boolean @default(false)
  accepteVirement  Boolean @default(false)

  // Notes sur les horaires
  horairesNote  String?

  // Relations
  categorie     Categorie     @relation(fields: [categorieId], references: [id])
  contributeur  User?         @relation("ContributeurActeur", fields: [contributeurId], references: [id])
  contributeurId String?
  photos        Photo[]
  horaires      Horaire[]
  avis          Avis[]
  tags          TagActeur[]
  evenements    Evenement[]

  // Score calculé (dénormalisé pour perf)
  noteAverage   Float?        @default(0)
  nbAvis        Int           @default(0)

  @@index([statut])
  @@index([categorieId, statut])
  @@map("acteurs")
}

model Categorie {
  id          String   @id @default(cuid())
  nom         String   @unique
  slug        String   @unique
  emoji       String?
  description String?
  ordre       Int      @default(0)
  acteurs     Acteur[]

  @@map("categories")
}

model Horaire {
  id        String   @id @default(cuid())
  acteurId  String
  jour      Jour
  ouvert    Boolean  @default(true)
  ouverture String?  // "08:00"
  fermeture String?  // "18:00"

  acteur    Acteur   @relation(fields: [acteurId], references: [id], onDelete: Cascade)

  @@unique([acteurId, jour])
  @@map("horaires")
}

enum Jour {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
}

model Photo {
  id        String   @id @default(cuid())
  acteurId  String?
  randoId   String?
  url       String
  alt       String?
  ordre     Int      @default(0)
  createdAt DateTime @default(now())

  acteur    Acteur?  @relation(fields: [acteurId], references: [id], onDelete: Cascade)
  rando     Rando?   @relation(fields: [randoId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Tag {
  id      String      @id @default(cuid())
  nom     String      @unique
  slug    String      @unique
  acteurs TagActeur[]

  @@map("tags")
}

model TagActeur {
  acteurId String
  tagId    String

  acteur   Acteur @relation(fields: [acteurId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([acteurId, tagId])
  @@map("tags_acteurs")
}

enum Statut {
  BROUILLON
  EN_ATTENTE
  PUBLIE
  ARCHIVE
}

// ─────────────────────────────────────────────
// AVIS & NOTES
// ─────────────────────────────────────────────

model Avis {
  id          String      @id @default(cuid())
  acteurId    String
  userId      String?
  prenomAuteur String?    // Pour les non-connectés
  estHabitant Boolean     @default(true)
  note        Int         // 1-5
  texte       String?
  statut      StatutAvis  @default(EN_ATTENTE)
  signale     Boolean     @default(false)
  nbUtiles    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  acteur      Acteur      @relation(fields: [acteurId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([acteurId, statut])
  @@map("avis")
}

enum StatutAvis {
  EN_ATTENTE
  APPROUVE
  REFUSE
  SIGNALE
}

// ─────────────────────────────────────────────
// ÉVÉNEMENTS / AGENDA
// ─────────────────────────────────────────────

model Evenement {
  id             String    @id @default(cuid())
  slug           String    @unique
  titre          String
  description    String?
  dateDebut      DateTime
  dateFin        DateTime?
  lieu           String?
  adresse        String?
  gratuit        Boolean   @default(true)
  prix           String?
  lienInscription String?
  imageUrl       String?
  statut         Statut    @default(EN_ATTENTE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Organisateur (lié à un acteur ou non)
  acteurId       String?
  contributeurId String?

  acteur         Acteur?   @relation(fields: [acteurId], references: [id], onDelete: SetNull)
  contributeur   User?     @relation("ContributeurEvenement", fields: [contributeurId], references: [id], onDelete: SetNull)

  @@map("evenements")
}

// ─────────────────────────────────────────────
// RANDONNÉES
// ─────────────────────────────────────────────

model Rando {
  id             String      @id @default(cuid())
  slug           String      @unique
  nom            String
  description    String?
  difficulte     Difficulte  @default(FACILE)
  distanceKm     Float?
  dureeMinutes   Int?
  deniveleM      Int?
  typeCircuit    TypeCircuit @default(BOUCLE)
  depart         String?
  gpxUrl         String?
  statut         Statut      @default(PUBLIE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  contributeurId String?
  contributeur   User?       @relation("ContributeurRando", fields: [contributeurId], references: [id], onDelete: SetNull)
  photos         Photo[]
  pointsInteret  PointInteret[]

  @@map("randos")
}

model PointInteret {
  id          String  @id @default(cuid())
  randoId     String
  nom         String
  description String?
  latitude    Float?
  longitude   Float?
  ordre       Int     @default(0)

  rando       Rando   @relation(fields: [randoId], references: [id], onDelete: Cascade)

  @@map("points_interet")
}

enum Difficulte {
  FACILE
  INTERMEDIAIRE
  DIFFICILE
}

enum TypeCircuit {
  BOUCLE
  ALLER_RETOUR
  LINEAIRE
}

// ─────────────────────────────────────────────
// ACTUALITÉS
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// PUSH NOTIFICATIONS
// ─────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model Actu {
  id             String   @id @default(cuid())
  slug           String   @unique
  titre          String
  contenu        String?
  source         String?  // "Mairie", "CCPA", "Association"...
  lienExterne    String?
  imageUrl       String?
  statut         Statut   @default(EN_ATTENTE)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contributeurId String?
  contributeur   User?    @relation(fields: [contributeurId], references: [id], onDelete: SetNull)

  @@map("actus")
}
